# ═══════════════════════════════════════════════════════════════════
# Demiurge Voice Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────
APP_NAME="Demiurge Voice Platform"
APP_VERSION=0.1.0
ENV=production
DEBUG=false

# ── Server ─────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ──────────────────────────────────────────
# Railway provides DATABASE_URL automatically
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/demiurge_voice

# ── LLM Providers (at least one required) ──────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=google/gemini-2.0-flash-001

OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ── STT / TTS ──────────────────────────────────────────────────────
STT_PROVIDER=whisper
STT_MODEL=base
WHISPER_API_KEY=

TTS_PROVIDER=kokoro
TTS_VOICE=af_bella

# ── LiveKit (optional — for real-time audio) ───────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Pipecat (optional — for pipeline orchestration) ────────────────
PIPECAT_DAILY_API_KEY=
PIPECAT_DEEPGRAM_API_KEY=
PIPECAT_CARTESIA_API_KEY=

# ── Telephony ──────────────────────────────────────────────────────
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Demiurge Ecosystem Integration ─────────────────────────────────
DEMIURGE_SECRETS_URL=
DEMIURGE_SECRETS_TOKEN=
DEMIURGE_LEAD_INTEL_URL=
DEMIURGE_LEAD_INTEL_TOKEN=
DEMIURGE_CONSOLE_URL=
DEMIURGE_CONSOLE_TOKEN=

# ── Security ───────────────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production
ADMIN_API_KEY=

# ── Audio Storage ──────────────────────────────────────────────────
RECORDING_STORAGE_PATH=/tmp/recordings
TRANSCRIPT_STORAGE_PATH=/tmp/transcripts
